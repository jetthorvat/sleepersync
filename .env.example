# Google Sheets CSV export URL for SFB16 Live Drafts ADP (columns A=ADP, B=Player).
# Optional override — defaults to the live SFB16 sheet if unset.
SFB16_LIVE_ADP_SHEET_URL=https://docs.google.com/spreadsheets/d/1Iu_5Z75Yarwj-1QqJlykYBIatazimCFhZsUl0VJx99Q/export?format=csv&gid=1432129336

# How long the server caches the sheet before refetching (seconds). Default: 900 (15 min).
SFB16_LIVE_ADP_REVALIDATE_SECONDS=900

# How often a live draft room auto-refreshes SFB16 rankings in the browser (ms). Default: 900000 (15 min).
NEXT_PUBLIC_SFB16_LIVE_ADP_REFRESH_MS=900000
