# Optional: Google Sheets CSV export URL for SFB16 Live Drafts ADP.
# 1. Share the sheet as "Anyone with the link can view"
# 2. Copy the export URL (replace SHEET_ID and TAB_GID):
#    https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=TAB_GID
# If unset, the app falls back to the bundled public/data/sfb16-live-drafts-adp.csv file.
SFB16_LIVE_ADP_SHEET_URL=

# How long the server caches the sheet before refetching (seconds). Default: 900 (15 min).
SFB16_LIVE_ADP_REVALIDATE_SECONDS=900

# How often a live draft room auto-refreshes SFB16 rankings in the browser (ms). Default: 900000 (15 min).
NEXT_PUBLIC_SFB16_LIVE_ADP_REFRESH_MS=900000
